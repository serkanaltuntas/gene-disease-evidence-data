{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serkan.ai/gene-disease-evidence/schemas/source-recheck.schema.json",
  "title": "Public Source Re-check Checklist",
  "type": "object",
  "required": [
    "checklist_version",
    "metadata_blocker_count",
    "release_id",
    "release_status",
    "required_human_checks",
    "research_use_only",
    "snapshot_count",
    "source_count",
    "sources",
    "status"
  ],
  "properties": {
    "checklist_version": { "const": "source-policy-public-recheck-v1" },
    "metadata_blocker_count": { "type": "integer" },
    "release_id": { "type": "string" },
    "release_status": { "type": "string" },
    "required_human_checks": { "type": "array", "items": { "type": "string" } },
    "research_use_only": { "type": "boolean" },
    "snapshot_count": { "type": "integer" },
    "source_count": { "type": "integer" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "accessed_at",
          "approved_for_public_release",
          "citation",
          "citation_url",
          "human_review",
          "license",
          "license_url",
          "metadata_problems",
          "metadata_status",
          "name",
          "recommended_citations",
          "snapshot_count",
          "snapshot_notes",
          "source_id",
          "terms_url",
          "version"
        ],
        "properties": {
          "accessed_at": { "type": "string" },
          "approved_for_public_release": { "type": "boolean" },
          "citation": { "type": "string" },
          "citation_url": { "type": "string" },
          "human_review": {
            "type": "object",
            "required": ["decision", "notes", "reviewed_at", "reviewer_id", "status"],
            "properties": {
              "decision": {
                "type": ["string", "null"],
                "enum": [null, "approved", "rejected", "needs_changes"]
              },
              "notes": { "type": "string" },
              "reviewed_at": { "type": ["string", "null"] },
              "reviewer_id": { "type": ["string", "null"] },
              "status": { "type": "string", "enum": ["pending", "reviewed"] }
            },
            "additionalProperties": false
          },
          "license": { "type": "string" },
          "license_url": { "type": "string" },
          "metadata_problems": { "type": "array", "items": { "type": "string" } },
          "metadata_status": { "type": "string", "enum": ["blocked", "ready_for_human_recheck"] },
          "name": { "type": "string" },
          "recommended_citations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "citation_type",
                "id",
                "source_page_url",
                "title",
                "url",
                "venue",
                "year"
              ],
              "properties": {
                "citation_type": { "type": "string" },
                "doi": { "type": "string" },
                "id": { "type": "string" },
                "pmcid": { "type": "string" },
                "pmid": { "type": "string" },
                "source_page_url": { "type": "string" },
                "title": { "type": "string" },
                "url": { "type": "string" },
                "venue": { "type": "string" },
                "year": { "type": "integer" }
              },
              "additionalProperties": false
            }
          },
          "snapshot_count": { "type": "integer" },
          "snapshot_notes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["accessed_at", "license_note", "snapshot_id", "version"],
              "properties": {
                "accessed_at": { "type": "string" },
                "license_note": { "type": "string" },
                "snapshot_id": { "type": "string" },
                "version": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "source_id": { "type": "string" },
          "terms_url": { "type": "string" },
          "version": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "status": { "type": "string", "enum": ["metadata_blocked", "pending_human_recheck"] }
  },
  "additionalProperties": false
}
