{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serkan.ai/gene-disease-evidence/schemas/source-snapshot.schema.json",
  "title": "Source Snapshot",
  "type": "object",
  "required": [
    "id",
    "source_ids",
    "path",
    "accessed_at",
    "version",
    "license_note",
    "record_count",
    "sha256"
  ],
  "properties": {
    "id": { "type": "string" },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "path": { "type": "string" },
    "accessed_at": { "type": "string" },
    "version": { "type": "string" },
    "license_note": { "type": "string" },
    "record_count": { "type": "integer" },
    "sha256": { "type": "string" }
  },
  "additionalProperties": false
}
