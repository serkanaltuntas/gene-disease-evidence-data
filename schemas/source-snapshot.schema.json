{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serkan.ai/gene-disease-evidence/schemas/source-snapshot.schema.json",
  "title": "Source Snapshot",
  "type": "object",
  "required": [
    "id",
    "source_ids",
    "path",
    "accessed_at",
    "version",
    "license_note",
    "record_count",
    "sha256"
  ],
  "properties": {
    "id": { "type": "string" },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "path": { "type": "string" },
    "accessed_at": { "type": "string" },
    "version": { "type": "string" },
    "license_note": { "type": "string" },
    "record_count": { "type": "integer" },
    "sha256": { "type": "string" },
    "freshness": {
      "type": "object",
      "required": ["assessed_at", "status", "basis", "paper_grade_blocker"],
      "properties": {
        "assessed_at": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["current", "refresh_recommended", "refresh_required", "unknown"]
        },
        "basis": { "type": "string" },
        "max_age_days": { "type": "integer", "minimum": 0 },
        "next_review_due": { "type": "string" },
        "paper_grade_blocker": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
