{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serkan.ai/gene-disease-evidence/schemas/source.schema.json",
  "title": "Source",
  "type": "object",
  "required": [
    "id",
    "name",
    "accessed_at",
    "version",
    "license_note",
    "license",
    "license_url",
    "terms_url",
    "citation",
    "citation_url",
    "recommended_citations",
    "approved_for_public_release"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "accessed_at": { "type": "string" },
    "version": { "type": "string" },
    "license_note": { "type": "string" },
    "license": { "type": "string" },
    "license_url": { "type": "string" },
    "terms_url": { "type": "string" },
    "citation": { "type": "string" },
    "citation_url": { "type": "string" },
    "recommended_citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "citation_type",
          "id",
          "source_page_url",
          "title",
          "url",
          "venue",
          "year"
        ],
        "properties": {
          "citation_type": { "type": "string" },
          "doi": { "type": "string" },
          "id": { "type": "string" },
          "pmcid": { "type": "string" },
          "pmid": { "type": "string" },
          "source_page_url": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "venue": { "type": "string" },
          "year": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "approved_for_public_release": { "type": "boolean" },
    "freshness": {
      "type": "object",
      "required": ["assessed_at", "status", "basis", "paper_grade_blocker"],
      "properties": {
        "assessed_at": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["current", "refresh_recommended", "refresh_required", "unknown"]
        },
        "basis": { "type": "string" },
        "max_age_days": { "type": "integer", "minimum": 0 },
        "next_review_due": { "type": "string" },
        "paper_grade_blocker": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
